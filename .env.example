# Copy to .env and fill in values you need.
# Never commit real secrets.

# ── LLM (Ollama preferred; APIs optional fallback) ──────────────────────────
AF_LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# OpenAI-compatible API (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

AF_LLM_TEMPERATURE=0.2
AF_LLM_MAX_TOKENS=4096

# ── Browser ─────────────────────────────────────────────────────────────────
AF_HEADLESS=false
AF_BROWSER_TIMEOUT_MS=30000
AF_MAX_RETRIES=3
AF_TYPING_DELAY_MS_MIN=40
AF_TYPING_DELAY_MS_MAX=120
AF_ACTION_PAUSE_MS_MIN=200
AF_ACTION_PAUSE_MS_MAX=800

# ── Paths (optional overrides) ──────────────────────────────────────────────
# AF_PERSONAL_DATA=personal_data.json
# AF_APPLICATION_LOG=application_log.json
# AF_LOGS_DIR=logs
# AF_SCREENSHOTS_DIR=screenshots

# ── Email: Tigrmail (optional) ──────────────────────────────────────────────
TIGRMAIL_API_KEY=
TIGRMAIL_BASE_URL=https://api.tigrmail.com

# ── Email: Gmail IMAP (optional — use an App Password) ──────────────────────
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_USER=
GMAIL_IMAP_PASSWORD=
GMAIL_IMAP_FOLDER=INBOX

# ── Firebase (public submissions + unique IDs) ──────────────────────────────
# Local worker / Streamlit: path to service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_key.json
# Netlify function alternative: paste the entire JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Shared secret for public form → Netlify function (also set in Netlify env)
SUBMISSION_SECRET=change-me-to-a-long-random-string

# Worker poll interval (seconds)
WORKER_POLL_INTERVAL_SEC=30

# Placeholder sign-up flow URLs — replace with your authorized targets
FLOW_NEWSLETTER_URL=https://example.com/newsletter-signup
FLOW_SAAS_TRIAL_URL=https://example.com/trial-signup
FLOW_JOB_PROFILE_URL=https://example.com/job-profile-create

# ── SMTP notification (unique ID email) ─────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=AutomationForge

# ── Netlify dashboard auth (hosted site only) ───────────────────────────────
# AUTH_SECRET=set-in-netlify-ui
