# Copy to .env and fill in. Never commit real secrets.

# ── LLM ─────────────────────────────────────────────────────────────────────
AF_LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
AF_LLM_TEMPERATURE=0.2
AF_LLM_MAX_TOKENS=4096

# ── Browser ─────────────────────────────────────────────────────────────────
AF_HEADLESS=false
AF_BROWSER_TIMEOUT_MS=30000
AF_MAX_RETRIES=3

# ── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_key.json
# FIREBASE_SERVICE_ACCOUNT_JSON=   # Netlify: full JSON one line
SUBMISSION_SECRET=change-me-to-a-long-random-string
WORKER_POLL_INTERVAL_SEC=30

# Sign-up flow URLs (replace placeholders)
FLOW_NEWSLETTER_URL=https://example.com/newsletter-signup
FLOW_SAAS_TRIAL_URL=https://example.com/trial-signup
FLOW_JOB_PROFILE_URL=https://example.com/job-profile-create

# ── Email (confirmation + follow-ups) ───────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=AutomationForge

# ── SMS (optional) ──────────────────────────────────────────────────────────
SEND_SMS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Paywall (OFF by default; Stripe or manual/GoDaddy) ──────────────────────
PAYWALL_ENABLED=false
PAYMENT_PROVIDER=stripe
# PAYMENT_PROVIDER=manual   # GoDaddy / invoice / other — form asks for paymentRef
PAYWALL_AMOUNT_CENTS=1999
PAYWALL_AMOUNT_LABEL=$19.99
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Netlify admin auth ──────────────────────────────────────────────────────
# AUTH_SECRET=set-in-netlify-ui
